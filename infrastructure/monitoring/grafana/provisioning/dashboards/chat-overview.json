{
  "title": "Chat System Overview",
  "uid": "chat-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(gateway_http_requests_total[1m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(gateway_http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(gateway_http_requests_total[1m]))", "legendFormat": "error %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 Latency by Route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (route, le))", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active WebSocket Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(socket_io_connected) by (instance)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka Producer Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(kafka_messages_produced_total[1m])) by (topic)", "legendFormat": "{{topic}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MongoDB Op/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(mongodb_op_counters_total[1m])", "legendFormat": "{{type}}" }
      ]
    }
  ]
}
